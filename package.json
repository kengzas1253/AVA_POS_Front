{
  "name": "AVAPOS",
  "productName": "AVAPOS",
  "version": "1.0.0",
  "description": "Electron desktop app built with React, Vite, and TypeScript",
  "main": "dist/main/main.js",
  "scripts": {
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "tsc -p tsconfig.renderer.json && vite build",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"npm:dev:electron\"",
    "dev:electron": "wait-on http://127.0.0.1:5173 && npm run build:main && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "start": "electron .",
    "package:win": "npm run build && electron-builder --win"
  },
  "keywords": [],
  "author": "ASIA MINIMART",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.asiaminimart.avapos",
    "productName": "AVA MY POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AVA MY POS"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^25.9.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "axios": "^1.18.0",
    "electron-context-menu": "^4.1.2",
    "electron-store": "^11.0.2",
    "html-to-image": "^1.11.13",
    "i18next": "^26.3.1",
    "jsbarcode": "^3.12.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^14.0.0"
  }
}
